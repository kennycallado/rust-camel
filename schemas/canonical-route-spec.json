{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalRouteSpec",
  "type": "object",
  "properties": {
    "auto_startup": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "circuit_breaker": {
      "anyOf": [
        {
          "$ref": "#/$defs/CanonicalCircuitBreakerSpec"
        },
        {
          "type": "null"
        }
      ]
    },
    "concurrency": {
      "anyOf": [
        {
          "$ref": "#/$defs/CanonicalConcurrencySpec"
        },
        {
          "type": "null"
        }
      ]
    },
    "from": {
      "type": "string"
    },
    "route_id": {
      "description": "Stable minimal route representation for runtime command registration.\n\nScope notes:\n- This is intentionally a partial model and does not mirror every `BuilderStep`.\n- Version 2 adds: auto_startup, startup_order, concurrency.\n- Still excluded: error_handler, unit_of_work. These are set to defaults\n  when compiling from canonical.\n- Round-trip (YAML → Canonical → YAML) loses these fields.\n- Advanced EIPs continue to use the existing RouteDefinition/BuilderStep path.",
      "type": "string"
    },
    "startup_order": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int32"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CanonicalStepSpec"
      }
    },
    "version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "route_id",
    "from",
    "steps",
    "version"
  ],
  "$defs": {
    "CanonicalAggregateSpec": {
      "type": "object",
      "properties": {
        "bucket_ttl_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "completion_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "completion_timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "correlation_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "discard_on_timeout": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "force_completion_on_stop": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "header": {
          "type": "string"
        },
        "max_buckets": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "strategy": {
          "$ref": "#/$defs/CanonicalAggregateStrategySpec"
        }
      },
      "required": [
        "header",
        "strategy"
      ]
    },
    "CanonicalAggregateStrategySpec": {
      "type": "string",
      "enum": [
        "collect_all"
      ]
    },
    "CanonicalCircuitBreakerSpec": {
      "type": "object",
      "properties": {
        "failure_threshold": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "open_duration_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "failure_threshold",
        "open_duration_ms"
      ]
    },
    "CanonicalConcurrencySpec": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "sequential"
            }
          },
          "required": [
            "mode"
          ]
        },
        {
          "type": "object",
          "properties": {
            "max": {
              "type": "integer",
              "format": "uint",
              "minimum": 0
            },
            "mode": {
              "type": "string",
              "const": "concurrent"
            }
          },
          "required": [
            "mode",
            "max"
          ]
        }
      ]
    },
    "CanonicalSplitAggregationSpec": {
      "type": "string",
      "enum": [
        "last_wins",
        "collect_all",
        "original"
      ]
    },
    "CanonicalSplitExpressionSpec": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "body_lines",
            "body_json_array"
          ]
        },
        {
          "type": "object",
          "properties": {
            "language": {
              "$ref": "#/$defs/LanguageExpressionDef"
            }
          },
          "additionalProperties": false,
          "required": [
            "language"
          ]
        },
        {
          "type": "object",
          "properties": {
            "stream": {
              "$ref": "#/$defs/StreamSplitConfig"
            }
          },
          "additionalProperties": false,
          "required": [
            "stream"
          ]
        }
      ]
    },
    "CanonicalStepSpec": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "uri": {
                  "type": "string"
                }
              },
              "required": [
                "uri"
              ]
            },
            "step": {
              "type": "string",
              "const": "to"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "message"
              ]
            },
            "step": {
              "type": "string",
              "const": "log"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "uri": {
                  "type": "string"
                }
              },
              "required": [
                "uri"
              ]
            },
            "step": {
              "type": "string",
              "const": "wire_tap"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "expression": {
                  "$ref": "#/$defs/LanguageExpressionDef"
                }
              },
              "required": [
                "expression"
              ]
            },
            "step": {
              "type": "string",
              "const": "script"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "predicate": {
                  "$ref": "#/$defs/LanguageExpressionDef"
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/CanonicalStepSpec"
                  }
                }
              },
              "required": [
                "predicate",
                "steps"
              ]
            },
            "step": {
              "type": "string",
              "const": "filter"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "otherwise": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "$ref": "#/$defs/CanonicalStepSpec"
                  }
                },
                "whens": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/CanonicalWhenSpec"
                  }
                }
              },
              "required": [
                "whens"
              ]
            },
            "step": {
              "type": "string",
              "const": "choice"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "aggregation": {
                  "$ref": "#/$defs/CanonicalSplitAggregationSpec"
                },
                "expression": {
                  "$ref": "#/$defs/CanonicalSplitExpressionSpec"
                },
                "parallel": {
                  "type": "boolean"
                },
                "parallel_limit": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "uint",
                  "minimum": 0
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/CanonicalStepSpec"
                  }
                },
                "stop_on_exception": {
                  "type": "boolean"
                }
              },
              "required": [
                "expression",
                "aggregation",
                "parallel",
                "stop_on_exception",
                "steps"
              ]
            },
            "step": {
              "type": "string",
              "const": "split"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "$ref": "#/$defs/CanonicalAggregateSpec"
            },
            "step": {
              "type": "string",
              "const": "aggregate"
            }
          },
          "required": [
            "step",
            "config"
          ]
        },
        {
          "type": "object",
          "properties": {
            "step": {
              "type": "string",
              "const": "stop"
            }
          },
          "required": [
            "step"
          ]
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "type": "object",
              "properties": {
                "delay_ms": {
                  "type": "integer",
                  "format": "uint64",
                  "minimum": 0
                },
                "dynamic_header": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "delay_ms"
              ]
            },
            "step": {
              "type": "string",
              "const": "delay"
            }
          },
          "required": [
            "step",
            "config"
          ]
        }
      ]
    },
    "CanonicalWhenSpec": {
      "type": "object",
      "properties": {
        "predicate": {
          "$ref": "#/$defs/LanguageExpressionDef"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CanonicalStepSpec"
          }
        }
      },
      "required": [
        "predicate",
        "steps"
      ]
    },
    "LanguageExpressionDef": {
      "description": "A language expression/predicate reference resolved by the runtime.",
      "type": "object",
      "properties": {
        "language": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "language",
        "source"
      ]
    },
    "StreamSplitConfig": {
      "description": "Configuration for splitting a streaming body into fragments.\n\nControls how the stream splitter processes the body, including format\ndetection, sizing limits, and metadata propagation.",
      "type": "object",
      "properties": {
        "batch_size": {
          "description": "Number of records/chunks to collect into a single exchange batch.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "chunk_size": {
          "description": "Explicit chunk size in bytes (required when format is [`Chunks`](StreamSplitFormat::Chunks)).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "format": {
          "description": "The streaming format to use.",
          "$ref": "#/$defs/StreamSplitFormat"
        },
        "include_origin": {
          "description": "Whether to include origin metadata in each fragment.",
          "type": "boolean"
        },
        "max_record_bytes": {
          "description": "Maximum size (in bytes) of a single record or chunk.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "format",
        "max_record_bytes",
        "batch_size",
        "include_origin"
      ]
    },
    "StreamSplitFormat": {
      "description": "The streaming format to use when splitting a stream body.",
      "oneOf": [
        {
          "description": "Auto-detect the format from the body content.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "Newline-delimited JSON — each line is a complete JSON value.",
          "type": "string",
          "const": "ndjson"
        },
        {
          "description": "Split by newlines, each line becomes a text fragment.",
          "type": "string",
          "const": "lines"
        },
        {
          "description": "Split into fixed-size byte chunks.",
          "type": "string",
          "const": "chunks"
        },
        {
          "description": "ZIP archive — materialized format, each entry becomes a fragment exchange.",
          "type": "string",
          "const": "zip"
        }
      ]
    }
  }
}